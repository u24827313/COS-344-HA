CXX      = g++
CXXFLAGS = -std=c++17 -Wall -Wextra -I include -I libs

# OpenGL / window libraries
LIBS     = -lGL -lGLFW -ldl

# Directories
SRC_DIR  = src
OBJ_DIR  = build

# ── Source files ─────────────────────────────────────────────
SRCS = $(SRC_DIR)/main.cpp \
       $(SRC_DIR)/scene/GolfCourse.cpp \
       $(SRC_DIR)/scene/Hole1.cpp 

#Object files
OBJS = $(SRCS:$(SRC_DIR)/%.cpp=$(OBJ_DIR)/%.o)

# ── Output binary ────────────────────────────────────────────
TARGET = golf

# ── Default target ───────────────────────────────────────────
all: $(TARGET)

$(TARGET): $(OBJS)
	$(CXX) $(CXXFLAGS) -o $@ $^ $(LIBS)

# ── Compile each .cpp into a .o ──────────────────────────────
$(OBJ_DIR)/%.o: $(SRC_DIR)/%.cpp
	@mkdir -p $(dir $@)
	$(CXX) $(CXXFLAGS) -c $< -o $@

# ── Utility targets ──────────────────────────────────────────
clean:
	rm -rf $(OBJ_DIR) $(TARGET)

run: all
	./$(TARGET)

.PHONY: all clean run